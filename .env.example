## Copy to ".env" (optional for local dev). Never commit ".env".
## Streamlit Cloud: set the same names under App settings → Secrets.

# --- API keys (RAG / LLM) ---
# GROQ_API_KEY is required for Milestone 2 RAG (`src/rag_pipeline.py` uses Groq).
#
# This file intentionally includes a shared Groq free-tier API key for the student project so
# teammates and graders can run the app without each creating a key. Treat it as PUBLIC: anyone
# with repository access can use or exhaust the quota; create your own key at
# https://console.groq.com/keys for private forks, production, or sensitive data.
GROQ_API_KEY=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
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# --- Read by app (src/retrieval.py, app/app.py) — all optional; sensible defaults exist ---
# Directory containing the notebook sample bundle (see README). Default: data/processed
# PROCESSED_DATA_DIR="data/processed"

# CSV path for 👍/👎 feedback rows. Default: {PROCESSED_DATA_DIR}/app_feedback.csv
# FEEDBACK_LOG_PATH="data/processed/app_feedback.csv"

