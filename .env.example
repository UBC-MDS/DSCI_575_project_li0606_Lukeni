## Copy to ".env" for local dev. Never commit ".env".
## Streamlit Cloud: set the same names under App → Secrets.

# --- RAG (Groq) ---
GROQ_API_KEY=[REPLACE_WITH_YOUR_KEY]
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# --- App paths (optional) ---
# PROCESSED_DATA_DIR="data/processed"
# FEEDBACK_LOG_PATH="data/processed/app_feedback.csv"

# --- Hugging Face (optional; speeds up / stabilizes embedding model download on Streamlit) ---
# HF_TOKEN=   # or HUGGINGFACEHUB_API_TOKEN — see https://huggingface.co/settings/tokens

# --- Hosted app: large `*_final` from a GitHub Release (see README → Outcomes) ---
# FETCH_REMOTE_ARTIFACTS=1
# REMOTE_ARTIFACTS_BASE_URL="https://github.com/JayLBean/data_model_storage/releases/download/0.0.1/"
